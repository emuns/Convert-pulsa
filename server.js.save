aconst express = require("express");
const multer = require("multer");
const cors = require("cors");

const app = express();

app.use(cors());
app.use(express.json());
app.use(express.static("public"));
app.use("/uploads", express.static("uploads"));

let transaksi = [];

// Upload config
const storage = multer.diskStorage({
  destination: (req, file, cb) => cb(null, "uploads/"),
  filename: (req, file, cb) =>
    cb(null, Date.now() + "-" + file.originalname),
});

const upload = multer({ storage });

// Kirim data
app.post("/kirim", upload.single("bukti"), (req, res) => {
  const { nomor, nominal, provider, tujuan } = req.body;

  const data = {
    id: Date.now(),
    nomor,
    nominal,
    provider,
    tujuan,
    bukti: req.file ? req.file.filename : null,
    status: "pending",
  };

  transaksi.push(data);

  res.json({ message: "Berhasil!" });
});

// Admin lihat data
app.get("/admin/transaksi", (req, res) => {
  res.json(transaksi);
});

// Update status
app.post("/admin/update/:id", (req, res) => {
  const id = parseInt(req.params.id);
  const { status } = req.body;

  transaksi = transaksi.map((t) =>
    t.id === id ? { ...t, status } : t
  );

  res.js
app.listen(3000, () => {
  console.log("Server jalan di http://localhost:3000");
})
